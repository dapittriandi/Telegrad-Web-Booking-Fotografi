<?php

namespace App\Http\Controllers;

use App\Models\Order;
use App\Models\Package;

use Illuminate\Http\Request;
use Illuminate\Support\Facades\DB;
use Carbon\Carbon;

class OrderController extends Controller
{
    public function store(Request $request)
    {
        $request->validate([
            'package_id'   => 'required|exists:packages,id',
            'booking_date' => 'required|date',
            'start_time'   => 'required',
            'location'     => 'nullable|string',
            'notes'        => 'nullable|string',
        ]);

        $package = Package::findOrFail($request->package_id);

        return DB::transaction(function () use ($request, $package) {

            $start = Carbon::parse($request->booking_date . ' ' . $request->start_time);
            $end   = (clone $start)->addMinutes((int) $package->duration);

            // CEK KONFLIK JADWAL (lebih aman)
            $conflict = Order::where('booking_date', $request->booking_date)
                ->where(function ($q) use ($start, $end) {
                    $q->where(function ($q2) use ($start, $end) {
                        $q2->where('start_time', '<', $end->format('H:i:s'))
                           ->where('end_time', '>', $start->format('H:i:s'));
                    });
                })
                ->exists();

            if ($conflict) {
                return back()->with('error', 'Jadwal sudah terisi, silakan pilih waktu lain.');
            }

            Order::create([
                'user_id'      => auth()->id(), // nanti kita kunci ke guard customer
                'package_id'   => $request->package_id,
                'booking_date' => $request->booking_date,
                'start_time'   => $start->format('H:i:s'),
                'end_time'     => $end->format('H:i:s'),
                'location'     => $request->location,
                'notes'        => $request->notes,
                'total_price'  => $package->price,
                'status'       => 'pending',
            ]);

            return redirect()->back()->with('success', 'Booking berhasil dibuat');
        });
    }
}